<?xml version="1.0" encoding="UTF-8"?>
<!--
    ZephyrOS — AOSP Source Slimming Manifest (v3, aggressive)
    Generated from android-14.0.0_r74/default.xml.

    Goal: fit AOSP source + build output within GitHub Actions
    runner disk (~84 GB after cleanup). Removes ~25 GB of
    device/kernel/trusty/hardware trees that GSI builds do not need.

    KEEP (whitelisted):
      device/generic/{arm64,armv7-a-neon,car,uml,x86_64}
      device/google/{gs-common,trout}
      hardware/{interfaces,libhardware,libhardware_legacy,ril}
      All framework/packages/system/art/libcore projects
-->
<manifest>

    <!-- ===== A. Testing suites (~5 GB) ===== -->
    <!-- NOTE: platform/cts 和 platform/platform_testing 已从移除清单中恢复.
         数十个 CTS 测试 app 的 Android.bp 引用了 "cts_defaults" defaults 模块,
         该模块定义在 platform/cts 项目中. 移除 cts 会导致 Soong 报
         "depends on undefined module cts_defaults" 错误.
         同样 platform_testing 也提供了测试基础设施, 一并恢复. -->
    <!-- NOTE: platform/test/app_compat/csuite 已从移除清单中恢复.
         art/test/Android.bp 和 WindowManager/Shell/tests 引用了
         csuite_test 模块类型, 该类型定义在 csuite 项目中.
         移除 csuite 会导致 Soong 报 "unrecognized module type" 错误. -->
    <remove-project name="platform/test/catbox" />
    <remove-project name="platform/test/cts-root" />
    <remove-project name="platform/test/dittosuite" />
    <!-- NOTE: platform/test/framework 已从移除清单中恢复.
         它定义了 rdroidtest.defaults 模块 (Rust 测试 defaults),
         被 packages/modules/Virtualization 和 system/secretkeeper 引用.
         移除会导致 Soong 报 "depends on undefined module rdroidtest.defaults" 错误. -->
    <!-- <remove-project name="platform/test/framework" /> -->
    <remove-project name="platform/test/mlts/benchmark" />
    <remove-project name="platform/test/mlts/models" />
    <!-- NOTE: platform/test/mts 已从移除清单中恢复.
         它定义了 mts-target-sdk-version-current defaults 模块,
         被 packages/modules/Permission, AdServices, Connectivity 引用.
         移除会导致 Soong 报 "depends on undefined module mts-target-sdk-version-current" 错误. -->
    <!-- <remove-project name="platform/test/mts" /> -->
    <remove-project name="platform/test/robolectric-extensions" />
    <remove-project name="platform/test/vts" />
    <remove-project name="platform/test/vts-testcase/hal" />
    <remove-project name="platform/test/vts-testcase/hal-trace" />
    <remove-project name="platform/test/vts-testcase/kernel" />
    <remove-project name="platform/test/vts-testcase/nbu" />
    <remove-project name="platform/test/vts-testcase/performance" />
    <remove-project name="platform/test/vts-testcase/security" />
    <remove-project name="platform/test/vts-testcase/vndk" />

    <!-- ===== B. PDK (~1 GB) ===== -->
    <remove-project name="platform/pdk" />

    <!-- ===== C. Emulator prebuilts (~3 GB) ===== -->
    <remove-project name="platform/prebuilts/android-emulator" />
    <remove-project name="platform/prebuilts/qemu-kernel" />

    <!-- ===== D. SDK / dev tools prebuilts (~2 GB) ===== -->
    <remove-project name="platform/prebuilts/abi-dumps/ndk" />
    <remove-project name="platform/prebuilts/abi-dumps/platform" />
    <remove-project name="platform/prebuilts/abi-dumps/vndk" />
    <remove-project name="platform/prebuilts/bundletool" />
    <remove-project name="platform/prebuilts/checkcolor" />
    <remove-project name="platform/prebuilts/checkstyle" />
    <remove-project name="platform/prebuilts/cmdline-tools" />
    <remove-project name="platform/prebuilts/devtools" />
    <remove-project name="platform/prebuilts/gradle-plugin" />
    <remove-project name="platform/prebuilts/ktlint" />
    <remove-project name="platform/prebuilts/manifest-merger" />

    <!-- ===== E. Trade Federation / misc test tools ===== -->
    <remove-project name="platform/tools/external/fat32lib" />
    <!-- NOTE: platform/tools/tradefederation/prebuilts 已从移除清单中恢复.
         它定义了 tradefed_errorprone_defaults defaults 模块,
         被 packages/modules/AdServices 的 device-collectors 引用.
         移除会导致 Soong 报 "depends on undefined module tradefed_errorprone_defaults" 错误. -->
    <!-- <remove-project name="platform/tools/tradefederation/prebuilts" /> -->

    <!-- ===== F. Docs & samples (~0.5 GB) ===== -->
    <remove-project name="platform/developers/build" />
    <remove-project name="platform/developers/demos" />
    <remove-project name="platform/developers/samples/android" />

    <!-- ================================================================ -->
    <!-- ===== G. NEW (v3): Device trees — Pixel & vendor-specific ===== -->
    <!--      GSI does not need device-specific trees.                  -->
    <!-- ================================================================ -->

