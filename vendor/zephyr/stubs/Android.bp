// =============================================================================
// ZephyrOS — Build Stubs
// -----------------------------------------------------------------------------
// 某些 AOSP 模块引用了 default manifest 中不存在的模块 (如 lint_api 定义在
// platform/tools/base 中, 但该巨型项目不在 android-14.0.0_r74 的 default.xml 里).
// 这些引用的模块仅用于开发工具 (apifinder, linter 等), 不影响系统镜像构建.
// 这里提供空壳 stub 以通过 Soong bootstrap 的依赖检查.
// =============================================================================
//
// 重要: 所有 stub 必须设置 sdk_version: "none" 和 system_modules: "none"!
// 如果 sdk_version 设置为 "current" 或默认值 "core_platform",
// java_library 的设备变体会依赖 android_stubs_current 或 core.platform.api.stubs,
// 而这些 SDK 桩的生成过程可能又依赖本 stub 文件中的模块,
// 导致依赖循环: android_stubs_current → ... → stub → android_stubs_current.
// 空壳模块没有源码, 不需要 SDK, 所以必须设 sdk_version: "none".
// 同时 Soong 要求在 sdk_version: "none" 时 system_modules 必须显式设置.

java_library {
    name: "lint_api",
    srcs: [],
    sdk_version: "none",
    system_modules: "none",
    host_supported: true,
}

java_library {
    name: "stub-annotations",
    srcs: [],
    sdk_version: "none",
    system_modules: "none",
    host_supported: true,
}

java_library {
    name: "metalava-signature-reader",
    srcs: [],
    sdk_version: "none",
    system_modules: "none",
    host_supported: true,
}

java_library {
    name: "lint",
    srcs: [],
    sdk_version: "none",
    system_modules: "none",
    host_supported: true,
}

java_library {
    name: "lint_tests",
    srcs: [],
    sdk_version: "none",
    system_modules: "none",
    host_supported: true,
}

java_library {
    name: "metalava-manual",
    srcs: [],
    sdk_version: "none",
    system_modules: "none",
    host_supported: true,
}

// private-stub-annotations-jar: 定义在 platform/tools/base 中, 被
// frameworks/base/api/StubLibraries.bp 中的 android_stubs_current.from-text
// android_system_stubs_current.from-text 和 android_test_stubs_current.from-text 引用.
java_library {
    name: "private-stub-annotations-jar",
    srcs: [],
    sdk_version: "none",
    system_modules: "none",
    host_supported: true,
}

// libvts_vintf_test_common: 定义在 platform/test/vts 中, 被 system/libvintf/Android.bp
// 中的 libassemblevintf 模块引用. 这是 VTS 测试库, 不影响 GSI 构建.
cc_library {
    name: "libvts_vintf_test_common",
    srcs: [],
    shared_libs: [],
    static_libs: [],
    header_libs: [],
    stl: "none",
    host_supported: true,
}