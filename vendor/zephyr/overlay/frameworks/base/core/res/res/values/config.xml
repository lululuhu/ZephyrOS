<?xml version="1.0" encoding="utf-8"?>
<!--
    ZephyrOS — Framework Resources Overlay
    ======================================
    覆盖 AOSP 默认 framework 配置，开启清风原创功能。
    所有覆盖项均使用 zephyr_ 前缀以避免与现有 ROM 冲突。
-->
<resources>

    <!-- 启用清风原创 status bar 自定义 -->
    <bool name="config_zephyr_status_bar_custom">true</bool>

    <!-- 启用三指截屏 -->
    <bool name="config_zephyr_three_finger_screenshot">true</bool>

    <!-- 启用清风胶囊（通知预览条） -->
    <bool name="config_zephyr_capsule_notify">true</bool>

    <!-- 启用单手模式 -->
    <bool name="config_zephyr_one_handed_mode">true</bool>

    <!-- 默认时区（中文用户） -->
    <string name="config_default_timezone">Asia/Shanghai</string>

    <!-- 关闭 AOSP 默认遥测 -->
    <bool name="config_default_enable_telemetry">false</bool>

    <!-- 清风手势：边缘滑动灵敏度（0-4，默认 2 中档） -->
    <integer name="config_zephyr_edge_swipe_sensitivity">2</integer>

    <!-- 清风手势：手势条样式（0=细 / 1=粗 / 2=隐藏） -->
    <integer name="config_zephyr_gesture_pill_style">0</integer>

</resources>
