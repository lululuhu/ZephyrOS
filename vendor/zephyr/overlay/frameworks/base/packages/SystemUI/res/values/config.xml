<?xml version="1.0" encoding="utf-8"?>
<!--
    ZephyrOS — SystemUI Resources Overlay
    =====================================
    覆盖 SystemUI 默认行为以接入清风原创功能模块。
-->
<resources>

    <!-- 状态栏图标最大数量（清风自定义时限制） -->
    <integer name="config_maxStatusIcons">6</integer>

    <!-- 横幅通知默认显示时长（ms），ZephyrParts 可调 -->
    <integer name="config_headsUpNotificationSnoozeDelay">3000</integer>

    <!-- 清风胶囊（原创通知预览）默认启用 -->
    <bool name="config_zephyr_capsule_enabled">true</bool>

    <!-- 默认电池图标样式：0=横向条 / 1=圆形 / 2=隐藏 -->
    <integer name="config_zephyr_battery_style">0</integer>

    <!-- 默认时钟位置：0=左 / 1=中 / 2=右 -->
    <integer name="config_zephyr_clock_position">1</integer>

    <!-- 启用网速胶囊（原创双箭头样式） -->
    <bool name="config_zephyr_net_speed_chip">true</bool>

</resources>
