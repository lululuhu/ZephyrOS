<?xml version="1.0" encoding="utf-8"?>
<!--
    ZephyrOS — About Header Layout
    "关于手机"页面顶部显示 ZephyrOS 品牌大图.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/zephyr_primary">

    <!-- ZephyrOS 图标 -->
    <ImageView
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:src="@drawable/ic_zephyr_logo"
        android:contentDescription="ZephyrOS" />

    <!-- 品牌名称 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="ZephyrOS"
        android:textSize="32sp"
        android:textColor="@android:color/white"
        android:textStyle="bold" />

    <!-- 版本副标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="1.0 · Breeze (清风)"
        android:textSize="14sp"
        android:textColor="@android:color/white"
        android:alpha="0.9" />

</LinearLayout>
