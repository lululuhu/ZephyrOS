<?xml version="1.0" encoding="utf-8"?>
<!--
    ZephyrOS — Launcher Overlay
    覆盖 AOSP framework 配置.

    注意: AOSP framework 中没有 config_default_launcher 等资源, 因此
    此 overlay 仅覆盖确实存在的资源. 默认桌面通过 default_launcher.xml
    (PRODUCT_COPY_FILES) 设置.
-->
<resources>

    <!-- 启用 recents 功能 (由 Lawnchair 自身处理) -->
    <bool name="config_recentsInterfaceForLegacyApps">true</bool>

</resources>
